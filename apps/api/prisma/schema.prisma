generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
}

enum UserRole {
  FAMILY_MEMBER
  FAMILY_HEAD
}

enum MemberStatus {
  PENDING_APPROVAL
  ACTIVE
  DEACTIVATED
}

enum RelationshipType {
  PARENT_CHILD
  SPOUSE
  SIBLING
}

enum InviteStatus {
  UNUSED
  USED
  EXPIRED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// Core Tables
// ─────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  nik          String       @unique
  passwordHash String
  role         UserRole     @default(FAMILY_MEMBER)
  status       MemberStatus @default(ACTIVE)
  refreshToken         String?
  referrerNik          String?
  referrerRelationship String?

  personNodes  PersonNode[]
  leaveRequests LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nik])
}

model FamilyGroup {
  id          String  @id @default(cuid())
  name        String
  description String?

  members       PersonNode[]
  invites       Invite[]
  notifications Notification[]
  leaveRequests LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id            String      @id @default(cuid())
  familyGroupId String
  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id])
  type          String
  message       String
  personNodeId  String?
  readAt        DateTime?

  createdAt DateTime @default(now())

  @@index([familyGroupId, createdAt])
}

model PersonNode {
  id            String    @id @default(cuid())
  displayName   String
  gender        Gender?
  surname       String?
  birthDate     DateTime?
  birthPlace    String?
  deathDate     DateTime?
  bio           String?
  avatarUrl     String?
  isDeceased    Boolean   @default(false)
  isPlaceholder   Boolean   @default(false)
  pendingApproval Boolean   @default(false)
  role          UserRole  @default(FAMILY_MEMBER)

  canvasX Float @default(0)
  canvasY Float @default(0)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  familyGroupId String?
  familyGroup   FamilyGroup? @relation(fields: [familyGroupId], references: [id])

  photos PersonPhoto[]

  relationshipsAsSource RelationshipEdge[] @relation("EdgeSource")
  relationshipsAsTarget RelationshipEdge[] @relation("EdgeTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, familyGroupId])
  @@index([familyGroupId])
}

model RelationshipEdge {
  id               String           @id @default(cuid())
  relationshipType RelationshipType

  sourceId String
  source   PersonNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId String
  target   PersonNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  marriageDate DateTime?
  divorceDate  DateTime?
  notes        String?

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relationshipType])
  @@index([sourceId])
  @@index([targetId])
}

model PersonPhoto {
  id        String    @id @default(cuid())
  url       String
  caption   String?
  takenAt   DateTime?
  sortOrder Int       @default(0)

  personNodeId String
  personNode   PersonNode @relation(fields: [personNodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Invite {
  id        String       @id @default(cuid())
  code      String       @unique
  status    InviteStatus @default(UNUSED)
  expiresAt DateTime

  familyGroupId String
  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id])

  createdAt DateTime  @default(now())
  usedAt    DateTime?
}

model LeaveRequest {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyGroupId String
  familyGroup   FamilyGroup        @relation(fields: [familyGroupId], references: [id])
  status        LeaveRequestStatus @default(PENDING)
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([userId, familyGroupId])
  @@index([familyGroupId])
}

model AuditLog {
  id            String   @id @default(cuid())
  familyGroupId String
  actorUserId   String
  action        String
  targetId      String?
  details       String?
  createdAt     DateTime @default(now())

  @@index([familyGroupId, createdAt])
}

model ShareToken {
  id              String   @id @default(cuid())
  token           String   @unique
  familyGroupId   String
  createdByUserId String
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([token])
}
